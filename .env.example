# NEURON OS Environment Variables Example
# Duplicate this file as '.env' and fill in values.

# Database url
# For local postgres: postgresql://username:password@localhost:5432/neuron
# For Docker: postgresql://neuron:neuron_pass@db:5432/neuron
# If using SQLite (default offline fallback): sqlite:///./neuron.db
DATABASE_URL=sqlite:///./neuron.db

# Authentication Signatures
JWT_SECRET=super-secret-neuron-key-change-in-production

# AI Orchestrator API Keys
# Add your API key to activate live LLM streaming response generation
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Waitlist email — use Gmail SMTP (easiest) or Resend
# Gmail: enable 2FA, create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=Neuron <your@gmail.com>
# Optional Resend fallback
RESEND_API_KEY=
RESEND_FROM_EMAIL=Neuron <onboarding@resend.dev>
WAITLIST_ADMIN_PASSWORD=neuron_admin_secret
PUBLIC_APP_URL=http://localhost:3000
